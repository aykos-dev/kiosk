{
  "name": "bellissimo-kiosk",
  "productName": "bellissimo-kiosk",
  "version": "1.0.0",
  "description": "Offline-first food service kiosk (Electron + React)",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build:mac": "electron-forge make --platform=darwin",
    "build:win": "electron-forge make --platform=win32",
    "publish": "electron-forge publish",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test": "node -e \"console.log('Add vitest/jest for unit tests')\"",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
  "author": {
    "name": "sardormahmudovbellissimo",
